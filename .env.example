# Copy this file to `.env.local` in the project root and fill in values
# from Supabase: Project Settings → API.
#
# URL = Project URL only: https://YOUR_PROJECT.supabase.co  (no /rest/v1/ suffix)
# Key = anon public JWT (eyJ…) or publishable (sb_publishable_…) — never sb_secret_ or service_role
#
# Use KEY=value with no spaces around "=" (spaces after "=" can break the URL).
# The app trims surrounding whitespace on load, but fixing the file avoids surprises.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare Turnstile (public site key). Required when Supabase Auth CAPTCHA is enabled for anonymous sign-in.
# Dashboard: Turnstile → create widget → Site key. Supabase: Authentication → Attack Protection → enable CAPTCHA (Turnstile) + secret key.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional: canonical public URL in production. Magic links use the browser origin on /sign-in if unset.
# Also used for share links, Open Graph previews, and hold-update emails.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Phase 9 — creator hold email updates (server-only; never expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
# NOTIFICATION_FROM_EMAIL=Comanifest <noreply@your-domain.com>
# Send-only address on your verified domain (Resend does not host inboxes for this).
# NOTIFICATION_REPLY_TO_EMAIL=hello@your-domain.com
# Real inbox for human replies (must forward/receive mail outside Resend).
# CRON_SECRET=  # Vercel Cron → Authorization: Bearer <CRON_SECRET>

# Optional: show /design-preview on non-local deploys (off by default; always on in npm run dev)
# NEXT_PUBLIC_ENABLE_DESIGN_PREVIEW=true

# Phase 10 — moderation review alerts (server-only)
# MODERATION_REVIEW_EMAIL=hello@comanifest.org

# Phase 11 — operator dashboard (/admin; server-only aggregates)
# Comma-separated emails allowed to open /admin after email sign-in.
# Defaults to MODERATION_REVIEW_EMAIL when unset.
# ADMIN_OPERATOR_EMAILS=you@example.com,teammate@example.com
# Uses SUPABASE_SERVICE_ROLE_KEY (above) — never expose to the browser.
